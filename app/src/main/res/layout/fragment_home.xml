<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeFragment"
    android:background="#E7E5E5">

    <!-- HERO IMAGE -->
    <ImageView
        android:id="@+id/imgHero"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:src="@drawable/homebanner"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DARK OVERLAY -->
    <View
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:background="#66000000"
        app:layout_constraintTop_toTopOf="@id/imgHero"
        app:layout_constraintStart_toStartOf="@id/imgHero"
        app:layout_constraintEnd_toEndOf="@id/imgHero"/>

    <!-- SEARCH BAR -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/cardSearch"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_margin="15dp"
        android:translationY="-30dp"
        app:queryHint="Search stores &amp; products"
        app:iconifiedByDefault="false"
        app:queryBackground="@android:color/transparent"
        app:submitBackground="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/imgHero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/search_view_background" />

    <!-- MAIN CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="vertical">

            <!-- CORE FEATURES (HIGHLIGHTED) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="30dp">

                <!-- PARKING -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="12dp"
                    android:layout_columnWeight="1"
                    android:id="@+id/parking">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#F57C00">

                        <ImageView
                            android:layout_width="213dp"
                            android:layout_height="157dp"
                            android:src="@drawable/parking" />


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 3D MAP -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="12dp"
                    android:layout_columnWeight="1"
                    android:id="@+id/map">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#FF9800">

                        <ImageView
                            android:layout_width="217dp"
                            android:layout_height="175dp"
                            android:src="@drawable/map" />


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- OFFERS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="12dp"
                    android:layout_columnWeight="1"
                    android:id="@+id/offers">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#E65100">

                        <ImageView
                            android:layout_width="216dp"
                            android:layout_height="212dp"
                            android:src="@drawable/offer" />


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- RESTAURANTS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="12dp"
                    android:layout_columnWeight="1"
                    android:id="@+id/restaurants">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#FB8C00">

                        <ImageView
                            android:layout_width="194dp"
                            android:layout_height="195dp"
                            android:src="@drawable/restaurants" />


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- FEATURED BRANDS -->
            <TextView
                android:layout_width="304dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Featured Brands"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/uniworth"
                        android:src="@drawable/uniworth"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp"/>

                    <ImageView
                        android:id="@+id/outfitters"
                        android:src="@drawable/outfitter"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp"/>

                    <ImageView
                        android:id="@+id/monark"
                        android:src="@drawable/monark"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp"/>

                    <ImageView
                        android:id="@+id/apple"
                        android:src="@drawable/apple"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="16dp"/>

                    <ImageView
                        android:id="@+id/cougar"
                        android:src="@drawable/cou"
                        android:layout_width="80dp"
                        android:layout_height="80dp"/>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
